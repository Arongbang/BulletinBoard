# ================================================================
#  BulletinBoard — 환경변수 예시 파일
#  이 파일을 복사해서 .env 로 이름 변경 후 실제 값을 채워 사용하세요:
#    cp .env.example .env
# ================================================================

# ── Oracle XE ──────────────────────────────────────────────────
ORACLE_SYS_PASSWORD=your_sys_password
ORACLE_APP_USER=board_user
ORACLE_APP_PASSWORD=your_app_password

# ── Spring Boot ─────────────────────────────────────────────────
# 운영 배포 시 실제 도메인으로 변경 (쉼표로 다중 지정 가능)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# JPA 옵션 — 스키마는 docker/oracle/init.sh 에서 관리하므로 none 유지
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_DDL_AUTO=none
